rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Функция-помощник: проверяет, что пользователь — мастер
    function isMaster() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'master';
    }

    // Функция-помощник: проверяет, что документ принадлежит текущему пользователю
    function isOwner() {
      return request.auth != null && request.auth.uid == resource.id;
    }

    // ========== Коллекция users ==========
    match /users/{userId} {

      // Создать профиль может только сам пользователь при регистрации
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['username', 'role']);

      // Читать профили может кто угодно (нужно для проверки username при регистрации,
      // просмотра профилей, списка участников фракции)
      allow read: if true;

      // Обновлять свой профиль может владелец
      // Мастер может обновлять любой профиль
      allow update: if request.auth != null && (
        request.auth.uid == userId
        || isMaster()
      );

      allow delete: if false; // Удаление через консоль Firebase
    }

    // ========== Коллекция notes ==========
    match /notes/{noteId} {

      // Создавать заметку может авторизованный пользователь
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;

      // Читать заметку может её автор или мастер
      allow read: if request.auth != null && (
        resource.data.authorId == request.auth.uid
        || isMaster()
      );

      // Обновлять заметку может только её автор
      allow update: if request.auth != null
        && resource.data.authorId == request.auth.uid;

      allow delete: if false;
    }

    // ========== Коллекция tags (каталог тегов) ==========
    match /tags/{tagId} {

      // Читать теги можно без авторизации (seed на старте, автокомплит)
      allow read: if true;

      // Создавать теги может любой авторизованный пользователь
      allow create: if request.auth != null;

      // Удалять теги может только мастер
      allow delete: if isMaster();
      allow update: if false;
    }

    // ========== Коллекция subtags (технические субтеги) ==========
    match /subtags/{subtagId} {

      // Читать субтеги могут все авторизованные
      allow read: if request.auth != null;

      // Создавать субтеги может любой авторизованный
      allow create: if request.auth != null;

      // Удалять субтеги может только мастер
      allow delete: if isMaster();
      allow update: if false;
    }

    // ========== Коллекция pages (страницы) ==========
    match /pages/{pageId} {

      // Читать страницы могут авторизованные пользователи
      // Фильтрация по фракциям/тегам происходит на клиенте
      allow read: if request.auth != null;

      // Создавать, редактировать и удалять страницы может только мастер
      allow create: if isMaster();
      allow update: if isMaster();
      allow delete: if isMaster();
    }
  }
}
